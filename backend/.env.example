# Copy to .env and fill. Never commit real tokens.
# Hugging Face: use a fine-grained token with "Make calls to Inference Providers"
# https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
HF_TOKEN=

# Optional model overrides (must be loadable on your HF Inference plan)
# Default classify model is DistilBERT-MNLI (faster; Bart often 504s on shared inference).
# HF_CLASSIFY_MODEL=typeform/distilbert-base-uncased-mnli
# HF_INFERENCE_TIMEOUT=90
# HF_NER_MODEL=dslim/bert-base-NER
# HF_GENERATE_MODEL=HuggingFaceTB/SmolLM2-1.7B-Instruct
# HF_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Batch clustering: use HF Inference feature_extraction (good on Render without PyTorch ST).
# HF_USE_REMOTE_EMBEDDINGS=true

# CORS — required for browser calls from Vercel to Render (comma-separated origins, no trailing slash)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://log-guard-seven.vercel.app

Render sets PORT automatically; local: uvicorn --port 8000 (Dockerfile uses ${PORT:-8000})
